# Build-time application settings only.
#
# Never put an AI provider API key in this file or in any VITE_* variable:
# Vite embeds VITE_* values into the public JavaScript bundle. Enter your key
# at runtime from ChefMind's Settings page instead.

VITE_APP_TITLE=ChefMind
VITE_APP_VERSION=3.1.5

# Optional: used only by the GitHub Pages deployment workflow.
# VITE_BASE_PATH=/ChefMind/
