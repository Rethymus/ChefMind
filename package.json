{
  "name": "chefmind-vue",
  "version": "3.1.2",
  "description": "ChefMind 智食谱 - 本地优先的 AI 厨房助手，覆盖菜谱生成、采购、烹饪指导和营养分析",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts",
    "lint:fix": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "format": "prettier --write src/",
    "type-check": "vue-tsc --noEmit",
    "db:init": "node scripts/init-db-simple.cjs",
    "db:reset": "node scripts/reset-database.js",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "screenshots": "playwright test scripts/capture-user-screenshots.spec.mjs --reporter=line",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "playwright test --config=playwright.config.mjs",
    "tauri:check": "cargo check --locked --manifest-path src-tauri/Cargo.toml"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@vueuse/core": "^13.9.0",
    "animate.css": "^4.1.1",
    "better-sqlite3": "^12.10.0",
    "element-plus": "^2.11.3",
    "html2canvas": "^1.4.1",
    "html2pdf.js": "^0.14.0",
    "pinia": "^3.0.3",
    "qrcode": "^1.5.4",
    "vue": "^3.3.4",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@tauri-apps/api": "^2.10.0",
    "@tauri-apps/cli": "^2.10.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.5.2",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "esbuild": "^0.27.7",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^16.5.0",
    "knip": "^6.16.1",
    "prettier": "^3.6.2",
    "sass": "^1.100.0",
    "terser": "^5.44.0",
    "typescript": "~5.9.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.4"
  },
  "keywords": [
    "vue",
    "typescript",
    "ai",
    "recipe",
    "cooking",
    "food",
    "智能菜谱",
    "烹饪",
    "美食",
    "enterprise",
    "monitoring",
    "caching",
    "database",
    "performance"
  ],
  "author": "ChefMind Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rethymus/ChefMind.git"
  },
  "bugs": {
    "url": "https://github.com/Rethymus/ChefMind/issues"
  },
  "homepage": "https://github.com/Rethymus/ChefMind#readme",
  "overrides": {
    "flatted": "^3.4.2",
    "lodash": "^4.18.1",
    "lodash-es": "^4.18.1",
    "picomatch": "^4.0.4"
  }
}
